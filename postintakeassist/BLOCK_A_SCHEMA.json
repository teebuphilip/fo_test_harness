{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post-Intake Block A (Canonical Snapshot)",
  "type": "object",
  "required": [
    "block_a_version",
    "pricing",
    "architecture",
    "acceptance_criteria",
    "integrations"
  ],
  "properties": {
    "block_a_version": {
      "type": "string"
    },
    "pricing": {
      "type": "object",
      "required": [
        "pricing_model",
        "billing_frequency",
        "tiers"
      ],
      "properties": {
        "pricing_model": {
          "type": "string",
          "enum": [
            "subscription",
            "one_time",
            "usage_based",
            "freemium",
            "unknown"
          ]
        },
        "billing_frequency": {
          "type": "string",
          "enum": [
            "monthly",
            "annual",
            "one_time",
            "unknown"
          ]
        },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "tier_id",
              "price_usd",
              "unit_limit"
            ],
            "properties": {
              "tier_id": {
                "type": "string",
                "pattern": "^T\\d+$"
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "price_usd": {
                "type": "number",
                "minimum": 0
              },
              "unit_limit": {
                "type": "object",
                "required": [
                  "unit",
                  "max"
                ],
                "properties": {
                  "unit": {
                    "type": "string",
                    "enum": [
                      "properties",
                      "clients",
                      "users",
                      "invoices",
                      "tasks",
                      "projects",
                      "unknown"
                    ]
                  },
                  "max": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "additionalProperties": false
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "freemium": {
          "type": "object",
          "properties": {
            "has_free": {
              "type": "boolean"
            },
            "conversion_mechanism": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "architecture": {
      "type": "object",
      "required": [
        "minimum_tier",
        "expected_timeline_days",
        "authentication_required",
        "payments_required",
        "subscription_billing",
        "dashboard_reporting",
        "pdf_generation",
        "external_apis",
        "background_jobs",
        "admin_panel"
      ],
      "properties": {
        "minimum_tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "expected_timeline_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "authentication_required": {
          "type": "boolean"
        },
        "payments_required": {
          "type": "boolean"
        },
        "subscription_billing": {
          "type": "boolean"
        },
        "dashboard_reporting": {
          "type": "boolean"
        },
        "pdf_generation": {
          "type": "boolean"
        },
        "external_apis": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0
        },
        "background_jobs": {
          "type": "boolean"
        },
        "admin_panel": {
          "type": "boolean"
        },
        "tech_stack": {
          "type": [
            "string",
            "null"
          ]
        },
        "deployment": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criteria_id",
          "text"
        ],
        "properties": {
          "criteria_id": {
            "type": "string",
            "minLength": 3
          },
          "text": {
            "type": "string",
            "minLength": 10
          },
          "metric": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "minItems": 0
    },
    "quantitative_bounds": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "metrics"
          ],
          "properties": {
            "metrics": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "unit",
                  "min",
                  "target",
                  "max"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "unit": {
                    "type": "string"
                  },
                  "min": {
                    "type": "number"
                  },
                  "target": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  },
                  "baseline": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": true
}