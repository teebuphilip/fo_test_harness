    {
      "template_id": "CT030_pricing_tiers",
      "title": "Provide explicit pricing tiers (no ranges)",
      "question": "Convert the pricing into explicit tiers. Provide tier IDs T1..Tn, price in USD, billing frequency, and the unit limit (e.g., properties/clients/users).",
      "response_schema": {
        "type": "object",
        "required": [
          "pricing"
        ],
        "properties": {
          "pricing": {
            "type": "object",
            "required": [
              "pricing_model",
              "billing_frequency",
              "tiers"
            ],
            "properties": {
              "pricing_model": {
                "type": "string",
                "enum": [
                  "subscription",
                  "one_time",
                  "usage_based",
                  "freemium",
                  "unknown"
                ]
              },
              "billing_frequency": {
                "type": "string",
                "enum": [
                  "monthly",
                  "annual",
                  "one_time",
                  "unknown"
                ]
              },
              "tiers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "tier_id",
                    "price_usd",
                    "unit_limit"
                  ],
                  "properties": {
                    "tier_id": {
                      "type": "string",
                      "pattern": "^T\\d+$"
                    },
                    "name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "price_usd": {
                      "type": "number",
                      "minimum": 0
                    },
                    "unit_limit": {
                      "type": "object",
                      "required": [
                        "unit",
                        "max"
                      ],
                      "properties": {
                        "unit": {
                          "type": "string",
                          "enum": [
                            "properties",
                            "clients",
                            "users",
                            "invoices",
                            "tasks",
                            "projects",
                            "unknown"
                          ]
                        },
                        "max": {
                          "type": "integer",
                          "minimum": 1
                        }
                      },
                      "additionalProperties": false
                    },
                    "notes": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              },
              "freemium": {
                "type": "object",
                "properties": {
                  "has_free": {
                    "type": "boolean"
                  },
                  "conversion_mechanism": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "apply_patch": [
        {
          "op": "replace",
          "path": "hero.constraints.economics",
          "from_answer": "pricing",
          "wrap": "{\"pricing\": <pricing>}"
        }
      ]
    },
