                "type": "boolean"
              },
              "role_based_access": {
                "type": "boolean"
              },
              "multi_tenant": {
                "type": "boolean"
              },
              "persistent_database": {
                "type": "boolean"
              },
              "payments_required": {
                "type": "boolean"
              },
              "subscription_billing": {
                "type": "boolean"
              },
              "dashboard_reporting": {
                "type": "boolean"
              },
              "pdf_generation": {
                "type": "boolean"
              },
              "external_apis": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 0
