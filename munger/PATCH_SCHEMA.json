{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Munger Patch",
  "type": "object",
  "required": [
    "patch_id",
    "rule_id",
    "op",
    "path",
    "before",
    "after",
    "reason",
    "confidence"
  ],
  "properties": {
    "patch_id": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "op": {
      "type": "string",
      "enum": [
        "add",
        "remove",
        "replace",
        "move"
      ]
    },
    "path": {
      "type": "string"
    },
    "from": {
      "type": [
        "string",
        "null"
      ]
    },
    "before": {},
    "after": {},
    "reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}